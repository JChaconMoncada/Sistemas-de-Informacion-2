<Page x:Class="Sistema_contable.Views.Cobranza"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:conv="clr-namespace:Sistema_contable.Converters"
      xmlns:vm="clr-namespace:Sistema_contable.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1100"
      Title="Cobranza">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Título + botón Nueva -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Gestión de Cobranza" Style="{StaticResource TitleTextBlock}" />
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"
                           Text="Registre y administre las facturas pendientes de cobro. Use '+ Nueva Factura' para agregar un cliente que le debe, luego márquela como Cobrada cuando reciba el pago." />
            </StackPanel>
            <Button Grid.Column="1" Content="+ Nueva Factura"
                    Command="{Binding NuevaFacturaCommand}"
                    Style="{StaticResource AccentButton}" Padding="14,6"
                    ToolTip="Registrar una nueva factura o deuda pendiente de cobro" />
        </Grid>

        <!-- Tarjetas resumen -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0,0,0,14">
            <Border Style="{StaticResource SummaryCard}" ToolTip="Facturas activas que aún no han sido cobradas">
                <StackPanel>
                    <TextBlock Text="Por Cobrar" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding Pendientes}" FontSize="26" FontWeight="Bold" Foreground="#FF9800" Margin="0,6,0,0" />
                    <TextBlock Text="{Binding MontoPendientes, StringFormat='Bs. {0:N2}'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                    <TextBlock Text="facturas pendientes" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCard}" ToolTip="Facturas cuya fecha de vencimiento ya pasó sin ser cobradas">
                <StackPanel>
                    <TextBlock Text="Vencidas (¡Urgente!)" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding Vencidas}" FontSize="26" FontWeight="Bold" Foreground="#F44336" Margin="0,6,0,0" />
                    <TextBlock Text="{Binding MontoVencidas, StringFormat='Bs. {0:N2}'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                    <TextBlock Text="requieren atención inmediata" FontSize="11" Foreground="#F44336" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryCard}" ToolTip="Total acumulado de facturas ya cobradas exitosamente">
                <StackPanel>
                    <TextBlock Text="Cobrado (total)" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding Cobradas}" FontSize="26" FontWeight="Bold" Foreground="#4CAF50" Margin="0,6,0,0" />
                    <TextBlock Text="{Binding MontoCobradas, StringFormat='Bs. {0:N2}'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                    <TextBlock Text="facturas cobradas" FontSize="11" Foreground="#4CAF50" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Filtros -->
        <GroupBox Grid.Row="2" Header="Buscar / Filtrar facturas" Margin="0,0,0,10"
                  ToolTip="Use los filtros para encontrar facturas específicas. Puede buscar por nombre de cliente, por estado o por rango de fechas.">
            <Grid Margin="6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding FiltroCliente, UpdateSourceTrigger=PropertyChanged}"
                         Tag="🔍 Buscar por cliente o N° factura..."
                         ToolTip="Escriba el nombre del cliente o el número de factura para buscar" />
                <ComboBox Grid.Column="2" SelectedValue="{Binding FiltroEstado}" SelectedValuePath="Content"
                          ToolTip="Filtre por estado: Pendiente = sin cobrar, Vencida = pasó la fecha, Pagada = ya cobrada">
                    <ComboBoxItem Content="Todos los estados" IsSelected="True" />
                    <ComboBoxItem Content="Pendiente" />
                    <ComboBoxItem Content="Vencida" />
                    <ComboBoxItem Content="Pagada" />
                    <ComboBoxItem Content="Anulada" />
                </ComboBox>
                <Label Grid.Column="4" Content="Desde:" VerticalAlignment="Center" Padding="0,0,4,0"
                       ToolTip="Fecha de emisión inicial" />
                <DatePicker Grid.Column="5" SelectedDate="{Binding FiltroDesde}" />
                <Label Grid.Column="7" Content="Hasta:" VerticalAlignment="Center" Padding="0,0,4,0"
                       ToolTip="Fecha de emisión final" />
                <DatePicker Grid.Column="8" SelectedDate="{Binding FiltroHasta}" />
                <Button Grid.Column="10" Content="Aplicar"
                        Command="{Binding AplicarFiltrosCommand}"
                        Style="{StaticResource AccentButton}" Padding="12,4"
                        ToolTip="Aplicar los filtros seleccionados" />
                <Button Grid.Column="12" Content="Limpiar"
                        Command="{Binding LimpiarFiltrosCommand}"
                        Padding="12,4"
                        ToolTip="Eliminar todos los filtros y ver todas las facturas" />
            </Grid>
        </GroupBox>

        <!-- DataGrid (solo lectura) -->
        <DataGrid Grid.Row="4" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" SelectionUnit="FullRow"
                  ItemsSource="{Binding Facturas}"
                  SelectedItem="{Binding FacturaSeleccionada, Mode=TwoWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nº Factura"     Width="130" Binding="{Binding NumeroFactura}" />
                <DataGridTextColumn Header="Cliente"        Width="*"   Binding="{Binding NombreCliente}" />
                <DataGridTextColumn Header="Descripción"    Width="180" Binding="{Binding Descripcion}" />
                <DataGridTextColumn Header="Emisión"        Width="95"  Binding="{Binding FechaEmision,    StringFormat=dd/MM/yyyy}" />
                <DataGridTextColumn Header="Vencimiento"    Width="95"  Binding="{Binding FechaVencimiento,StringFormat=dd/MM/yyyy}" />
                <DataGridTextColumn Header="Monto"          Width="110" Binding="{Binding Monto, StringFormat=N2}" />
                <DataGridTemplateColumn Header="Estado" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="6,2" CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FF9800" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Estado}" Value="Vencida">
                                                <Setter Property="Background" Value="#F44336" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Estado}" Value="Pagada">
                                                <Setter Property="Background" Value="#4CAF50" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Estado}" Value="Anulada">
                                                <Setter Property="Background" Value="#9E9E9E" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Estado}" FontSize="11"
                                           Foreground="White" FontWeight="SemiBold" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Tipo de Pago"   Width="110" Binding="{Binding TipoPago}" />
                <DataGridTextColumn Header="Días Vencido"   Width="90"  Binding="{Binding DiasVencido}" />
                <DataGridTemplateColumn Header="Acciones" Width="210">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="2,2">
                                <Button Content="✔ Cobrar"
                                        Height="26" Padding="8,0" Margin="0,0,4,0"
                                        FontSize="11" FontWeight="SemiBold"
                                        Foreground="White" Background="#388E3C"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="Registrar el pago: marca la factura como cobrada y genera el asiento contable"
                                        Command="{Binding DataContext.MarcarPagadaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="✏ Editar"
                                        Height="26" Padding="8,0" Margin="0,0,4,0"
                                        FontSize="11"
                                        Foreground="White" Background="#1976D2"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="Modificar los datos de esta factura (cliente, descripción, tipo de pago, fecha)"
                                        Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="✕ Anular"
                                        Height="26" Padding="8,0"
                                        FontSize="11"
                                        Foreground="White" Background="#D32F2F"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="Cancelar esta factura (no se puede cobrar una factura anulada)"
                                        Command="{Binding DataContext.AnularCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Panel formulario (nueva/editar factura) -->
        <Border Grid.Row="5"
                Visibility="{Binding EstaEnModoEdicion, Converter={StaticResource BoolToVis}}"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,2,0,0"
                Background="{StaticResource WindowBackgroundBrush}"
                Padding="0,12,0,0" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="{Binding TituloFormulario}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               Text="Complete los campos obligatorios (*) y haga clic en Guardar." />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Cliente *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3" />
                        <TextBox Text="{Binding EditCliente, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Nombre completo de la persona o empresa que debe pagar" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Descripción / Concepto" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3" />
                        <TextBox Text="{Binding EditDescripcion, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Describa brevemente por qué se genera este cobro (ej: Servicio de contabilidad enero)" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Monto *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3" />
                        <TextBox Text="{Binding EditMonto, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding MontoEditable}"
                                 ToolTip="Monto total a cobrar en Bolívares. No se puede modificar después de guardar." />
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Fecha Vencimiento *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3" />
                        <DatePicker SelectedDate="{Binding EditFechaVencimiento}"
                                    ToolTip="Fecha límite para recibir el pago. Al superarla, la factura pasará a estado Vencida." />
                    </StackPanel>
                </Grid>

                <!-- Fila 2 del formulario: Tipo de Pago -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tipo de Pago *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3" />
                        <ComboBox ItemsSource="{x:Static vm:CobranzaViewModel.OpcionesTipoPago}"
                                  SelectedItem="{Binding EditTipoPago}"
                                  ToolTip="Indique la naturaleza del cobro: Mensualidad=cobro recurrente mensual, Pago Único=cobro de una sola vez, Pago Pendiente=deuda anterior, Abono Parcial=pago parcial de una deuda mayor" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="💾  Guardar Factura"
                            Command="{Binding GuardarCommand}"
                            Style="{StaticResource AccentButton}"
                            Padding="16,6" Margin="0,0,8,0"
                            ToolTip="Guardar la factura y generar el asiento contable correspondiente" />
                    <Button Content="✕  Cancelar"
                            Command="{Binding CancelarEdicionCommand}"
                            Padding="16,6"
                            ToolTip="Cerrar el formulario sin guardar cambios" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
