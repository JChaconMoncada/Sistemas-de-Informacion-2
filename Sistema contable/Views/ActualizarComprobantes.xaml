<Window x:Class="Sistema_contable.Views.ActualizarComprobantes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Actualizar Comprobantes"
        Height="560" Width="920"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Actualizar Comprobantes" Style="{StaticResource TitleTextBlock}" />
        <TextBlock Grid.Row="1"
                   Text="Recalcula los saldos y verifica la integridad de los comprobantes contables en el rango de fechas seleccionado."
                   Style="{StaticResource SubtitleTextBlock}" Margin="0,0,0,16" />

        <!-- Filtros -->
        <GroupBox Grid.Row="2" Header="Filtros de Búsqueda" Margin="0,0,0,12">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Desde:" VerticalAlignment="Center" />
                <DatePicker Grid.Column="1" x:Name="DtpDesde" />

                <Label Grid.Column="3" Content="Hasta:" VerticalAlignment="Center" />
                <DatePicker Grid.Column="4" x:Name="DtpHasta" />

                <Label Grid.Column="6" Content="Tipo:" VerticalAlignment="Center" />
                <ComboBox Grid.Column="7" x:Name="CmbTipo">
                    <ComboBoxItem Content="Todos" IsSelected="True" />
                    <ComboBoxItem Content="Manual" />
                    <ComboBoxItem Content="Apertura" />
                    <ComboBoxItem Content="Cierre" />
                    <ComboBoxItem Content="Ajuste" />
                    <ComboBoxItem Content="Reexpresión" />
                </ComboBox>

                <Button Grid.Column="9" Content="Buscar" Style="{StaticResource AccentButton}"
                        Click="BtnBuscar_Click" Margin="6,0,0,0" Padding="12,5" />
            </Grid>
        </GroupBox>

        <!-- Opciones de actualización -->
        <GroupBox Grid.Row="3" Header="Opciones de Actualización" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="8">
                <CheckBox x:Name="ChkRecalcularSaldos" Content="Recalcular saldos de cuentas"
                          IsChecked="True" Margin="0,0,20,0" />
                <CheckBox x:Name="ChkVerificarIntegridad" Content="Verificar integridad de asientos"
                          IsChecked="True" Margin="0,0,20,0" />
                <CheckBox x:Name="ChkActualizarReferencias" Content="Actualizar referencias de cuentas"
                          IsChecked="False" />
            </StackPanel>
        </GroupBox>

        <!-- DataGrid de comprobantes -->
        <DataGrid Grid.Row="4" x:Name="GridComprobantes" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True" Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Sel." Width="45" />
                <DataGridTextColumn Header="N° Comprobante" Width="130" Binding="{Binding IdComprobante}" />
                <DataGridTextColumn Header="Fecha" Width="100" Binding="{Binding Fecha}" />
                <DataGridTextColumn Header="Tipo" Width="100" Binding="{Binding TipoComprobante}" />
                <DataGridTextColumn Header="Descripción" Width="*" Binding="{Binding Descripcion}" />
                <DataGridTextColumn Header="Total Debe" Width="120" Binding="{Binding TotalDebe, StringFormat=N2}" />
                <DataGridTextColumn Header="Total Haber" Width="120" Binding="{Binding TotalHaber, StringFormat=N2}" />
                <DataGridTemplateColumn Header="Estado" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="4,2" HorizontalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2EFDA" />
                                        <Setter Property="BorderBrush" Value="#217346" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Estado}" Value="Error">
                                                <Setter Property="Background" Value="#FDE8E8" />
                                                <Setter Property="BorderBrush" Value="#E53935" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                                <Setter Property="Background" Value="#FFF3E0" />
                                                <Setter Property="BorderBrush" Value="#FF9800" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Barra de progreso -->
        <Border Grid.Row="5" x:Name="PanelProgreso" Visibility="Collapsed"
                Background="{StaticResource AccentLightBrush}"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                Padding="12,8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="TxtProgreso" Text="Actualizando comprobantes..."
                           FontWeight="SemiBold" Margin="0,0,0,4" />
                <ProgressBar x:Name="BarraProgreso" Height="16" Minimum="0" Maximum="100" Value="0" />
            </StackPanel>
        </Border>

        <!-- Botones -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Seleccionar Todos" Click="BtnSeleccionarTodos_Click" Margin="0,0,6,0" Padding="16,8" />
            <Button Content="Actualizar Seleccionados" Style="{StaticResource AccentButton}"
                    Click="BtnActualizar_Click" Margin="0,0,6,0" Padding="16,8" />
            <Button Content="Cerrar" Click="BtnCerrar_Click" Padding="16,8" />
        </StackPanel>
    </Grid>
</Window>
