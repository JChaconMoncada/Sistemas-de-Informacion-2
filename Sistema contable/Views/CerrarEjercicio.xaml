<Window x:Class="Sistema_contable.Views.CerrarEjercicio"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cerrar Ejercicio Fiscal"
        Height="640" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Cierre de Ejercicio Fiscal" Style="{StaticResource TitleTextBlock}" />
        <TextBlock Grid.Row="1"
                   Text="Este proceso cierra las cuentas de resultados y traslada saldos al balance. Esta acción no puede deshacerse."
                   Style="{StaticResource SubtitleTextBlock}" Margin="0,0,0,16" />

        <!-- Advertencia -->
        <Border Grid.Row="2" Background="#FFF3E0" BorderBrush="#FF9800" BorderThickness="1"
                Padding="12,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="18" Foreground="#FF9800" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock TextWrapping="Wrap" Foreground="#E65100" VerticalAlignment="Center">
                    <Run FontWeight="Bold" Text="Advertencia: " />
                    <Run Text="Asegúrese de que todos los comprobantes estén actualizados y cuadrados antes de cerrar el ejercicio. Se recomienda hacer un backup antes de continuar." />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Selección de ejercicio -->
        <GroupBox Grid.Row="3" Header="Ejercicio a Cerrar" Margin="0,0,0,12">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Ejercicio:" VerticalAlignment="Center" />
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CmbEjercicio" SelectionChanged="CmbEjercicio_SelectionChanged">
                    <ComboBoxItem Content="2025" IsSelected="True" />
                    <ComboBoxItem Content="2024" />
                    <ComboBoxItem Content="2023" />
                </ComboBox>

                <Label Grid.Row="0" Grid.Column="3" Content="Inicio:" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtFechaInicio" Text="01/01/2025" IsReadOnly="True" />

                <Label Grid.Row="0" Grid.Column="6" Content="Fin:" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="7" x:Name="TxtFechaFin" Text="31/12/2025" IsReadOnly="True" />

                <!-- Resumen del ejercicio -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="8"
                        Background="{StaticResource ContentBackgroundBrush}"
                        BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1"
                        Padding="12" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Total Ingresos" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="TxtTotalIngresos" Text="Bs. 0.00" HorizontalAlignment="Center"
                                       FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Total Gastos" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="TxtTotalGastos" Text="Bs. 0.00" HorizontalAlignment="Center"
                                       FontSize="20" FontWeight="Bold" Foreground="#E53935" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Resultado del Ejercicio" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                            <TextBlock x:Name="TxtResultado" Text="Bs. 0.00" HorizontalAlignment="Center"
                                       FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </GroupBox>

        <!-- DataGrid de asientos de cierre -->
        <GroupBox Grid.Row="4" Header="Asientos de Cierre a Generar" Margin="0,0,0,12">
            <DataGrid x:Name="GridAsientosCierre" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Incluir" Width="60" />
                    <DataGridTextColumn Header="Tipo de Asiento" Width="200" Binding="{Binding TipoAsiento}" />
                    <DataGridTextColumn Header="Cuenta Origen" Width="*" Binding="{Binding CuentaOrigen}" />
                    <DataGridTextColumn Header="Cuenta Destino" Width="*" Binding="{Binding CuentaDestino}" />
                    <DataGridTextColumn Header="Monto" Width="140" Binding="{Binding Monto, StringFormat=N2}" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Confirmación -->
        <Border Grid.Row="5" Background="#FDE8E8" BorderBrush="#E53935" BorderThickness="1"
                Padding="12,10" Margin="0,0,0,12">
            <CheckBox x:Name="ChkConfirmacion" Foreground="#B71C1C" FontWeight="SemiBold"
                      Content="Confirmo que deseo cerrar el ejercicio fiscal. Entiendo que esta acción bloqueará el período seleccionado." />
        </Border>

        <!-- Botones -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Calcular Asientos" Click="BtnCalcular_Click" Margin="0,0,6,0" Padding="16,8" />
            <Button Content="Cerrar Ejercicio" Style="{StaticResource AccentButton}"
                    Click="BtnCerrarEjercicio_Click" Margin="0,0,6,0" Padding="16,8" />
            <Button Content="Cancelar" Click="BtnCancelar_Click" Padding="16,8" />
        </StackPanel>
    </Grid>
</Window>
