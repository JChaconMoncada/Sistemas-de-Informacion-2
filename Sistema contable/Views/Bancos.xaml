<Page x:Class="Sistema_contable.Views.Bancos"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:Sistema_contable.Converters"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="Bancos">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Importación de Estados de Cuenta Bancarios (PDF)" Style="{StaticResource TitleTextBlock}" />
        <TextBlock Grid.Row="1" Text="Extrae automáticamente las transacciones de archivos PDF y permite mapearlas a cuentas contables" 
                   Style="{StaticResource SubtitleTextBlock}" Margin="0,0,0,16" />

        <GroupBox Grid.Row="2" Header="Seleccionar Archivo PDF" Margin="0,0,0,12">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" IsReadOnly="True" Margin="0,0,8,0" Text="{Binding FilePath, Mode=TwoWay}">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Ningún archivo seleccionado..." 
                                                               Foreground="{StaticResource TextPlaceholderBrush}" 
                                                               Margin="8,0,0,0" />
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <Button Grid.Column="1" Content="Seleccionar PDF" Style="{StaticResource AccentButton}" Command="{Binding SeleccionarPdfCommand}" />
            </Grid>
        </GroupBox>

        <Border Grid.Row="3" Background="{StaticResource AccentLightBrush}" 
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" 
                Padding="12" Margin="0,0,0,12" 
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Procesando archivo..." FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
                <ProgressBar Grid.Column="1" Value="{Binding ProgressValue}" Maximum="100" Height="20" />
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="1*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Columna Izquierda: Tabla y botones -->
            <DockPanel Grid.Column="0">
                <!-- Botones superiores de la tabla -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Agregar Fila" Command="{Binding AgregarFilaCommand}" Style="{StaticResource AccentButton}" Margin="0,0,8,0" Padding="12,6" />
                    <Button Content="Eliminar Fila Seleccionada" Command="{Binding EliminarFilaCommand}" CommandParameter="{Binding SelectedItem, ElementName=GridTransacciones}" Margin="0,0,8,0" Padding="12,6" />
                    <Button Content="Eliminar Errores (Rojos)" Command="{Binding EliminarErroresCommand}" Background="#D32F2F" Foreground="White" BorderThickness="0" Margin="0,0,8,0" Padding="12,6" />
                </StackPanel>

                <GroupBox Header="Transacciones Extraídas - Mapeo a Cuentas Contables">
                    <!-- DataGrid editable -->
                    <DataGrid x:Name="GridTransacciones" AutoGenerateColumns="False" CanUserAddRows="False" 
                              SelectionUnit="FullRow"
                              ItemsSource="{Binding Transacciones}" 
                              SelectedItem="{Binding SelectedTransaccion, Mode=TwoWay}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                        <Setter Property="Background" Value="#FFF0F0" />
                                        <Setter Property="ToolTip" Value="Revise y corrija los datos manualmente para esta línea no reconocida." />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Importar" Width="60" Binding="{Binding Importar, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="Fecha" Width="95" Binding="{Binding Fecha, Mode=TwoWay, StringFormat=dd/MM/yyyy, UpdateSourceTrigger=LostFocus}" />
                            <DataGridTextColumn Header="Referencia" Width="95" Binding="{Binding Referencia, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <DataGridTextColumn Header="Descripción" Width="*" Binding="{Binding Descripcion, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <DataGridTextColumn Header="Débito" Width="90" Binding="{Binding Debito, Mode=TwoWay, StringFormat=N2, UpdateSourceTrigger=LostFocus}" />
                            <DataGridTextColumn Header="Crédito" Width="90" Binding="{Binding Credito, Mode=TwoWay, StringFormat=N2, UpdateSourceTrigger=LostFocus}" />
                            <DataGridTemplateColumn Header="Cuenta Contable" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.CuentasContables, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  SelectedItem="{Binding CuentaSeleccionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="DisplayName">
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Acción" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑" Foreground="#D32F2F" Background="Transparent" BorderThickness="0" 
                                                Cursor="Hand" ToolTip="Eliminar Fila" FontWeight="Bold" FontSize="14"
                                                Command="{Binding DataContext.EliminarFilaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </DockPanel>

            <!-- Splitter de redimensionamiento -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="4" Background="#E0E0E0" ShowsPreview="True" Margin="6,0" />

            <!-- Columna Derecha: Vista Previa Texto Crudo PDF -->
            <GroupBox Grid.Column="2" Header="Vista Previa del PDF Original">
                <wv2:WebView2 x:Name="PdfWebViewer" MinWidth="300" />
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="Transacciones seleccionadas: " FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="{Binding SelectedTransactionsCount}" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Importar Transacciones" Style="{StaticResource AccentButton}" Margin="0,0,6,0" Padding="16,8" Command="{Binding ImportarTransaccionesCommand}" />
            <Button Content="Cancelar" Padding="16,8" Command="{Binding CancelarCommand}" />
        </StackPanel>
    </Grid>
</Page>