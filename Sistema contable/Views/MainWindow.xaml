<Window x:Class="Sistema_contable.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Oficina Contable Zulay Angola - Sistema Contable ERP" 
        Height="800" Width="1400"
        WindowState="Maximized">
    
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="{StaticResource HeaderBackgroundBrush}" Padding="4">
            <MenuItem Header="_Archivo">
                <Separator />
                <MenuItem Header="Salir" Click="MenuSalir_Click" />
            </MenuItem>
            <MenuItem Header="_Empresas">
                <MenuItem Header="Nueva Empresa" Click="MenuNuevaEmpresa_Click" />
                <MenuItem Header="Editar Empresa" Click="MenuEmpresas_Click" />
                <MenuItem Header="Eliminar Empresa" Click="MenuEmpresas_Click" />
            </MenuItem>
            <MenuItem Header="_Contabilidad">
                <MenuItem Header="Nuevo Comprobante" Click="MenuComprobante_Click" />
                <MenuItem Header="Plan de Cuentas" Click="MenuPlanCuentas_Click" />
                <MenuItem Header="Libro Diario" Click="MenuLibroDiario_Click" />
                <MenuItem Header="Libro Mayor" Click="MenuLibroMayor_Click" />
            </MenuItem>
            <MenuItem Header="_Procesos">
                <MenuItem Header="Actualizar Comprobantes" Click="MenuActualizarComprobantes_Click" />
                <MenuItem Header="Reversar Comprobante" Click="MenuReversarComprobante_Click" />
                <Separator />
                <MenuItem Header="Importar de Excel">
                    <MenuItem Header="Comprobantes" Click="MenuImportarExcelComprobantes_Click" />
                    <MenuItem Header="Plan de Cuentas" Click="MenuImportarExcelPlanCuentas_Click" />
                </MenuItem>
                <MenuItem Header="Planillas">
                    <MenuItem Header="Sueldos y Salarios" Click="MenuPlanillasSueldos_Click" />
                    <MenuItem Header="Impuestos y Retenciones" Click="MenuPlanillasImpuestos_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Cerrar Ejercicio" Click="MenuCerrarEjercicio_Click" />
                <Separator />
                <MenuItem Header="Reexpresión por Inflación (IPC)" Click="MenuReexpresion_Click" />
                <MenuItem Header="Reconversión Monetaria 2021" Click="MenuReconversion2021_Click" />
            </MenuItem>
            <MenuItem Header="_Reportes">
                <MenuItem Header="Estado Financiero Detallado" Click="MenuEstadoFinanciero_Click" />
                <Separator />
                <MenuItem Header="Balance General" Click="MenuInformes_Click" />
                <MenuItem Header="Estado de Resultados" Click="MenuInformes_Click" />
                <MenuItem Header="Flujo de Efectivo" Click="MenuInformes_Click" />
            </MenuItem>
            <MenuItem Header="_Herramientas">
                <MenuItem Header="Abrir Carpeta de Backups" Click="MenuAbrirCarpetaBackups_Click" />
                <Separator />
                <MenuItem Header="Reexpresión Monetaria" Click="MenuReexpresion_Click" />
                <MenuItem Header="Importar PDF Bancario" Click="MenuBancos_Click" />
            </MenuItem>
            <MenuItem Header="A_yuda">
                <MenuItem Header="Manual de Usuario" Click="MenuAyuda_Click" />
                <MenuItem Header="Acerca de" Click="MenuAcercaDe_Click" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource HeaderBackgroundBrush}" Padding="8,4">
            <StatusBarItem>
                <TextBlock Text="{Binding TextoEstado}" Foreground="{StaticResource TextPrimaryBrush}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding UltimoBackupStatus}" Foreground="{StaticResource TextSecondaryBrush}" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource WindowBackgroundBrush}" 
                    BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- ── Encabezado Empresas ── -->
                    <Border DockPanel.Dock="Top" Background="{StaticResource DataGridHeaderBackgroundBrush}" 
                            Padding="12,8" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="EMPRESAS" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="+ Nueva" Padding="7,3" Margin="0,0,4,0"
                                        Style="{StaticResource AccentButton}" FontSize="11"
                                        Click="BtnGestionarEmpresas_Click" ToolTip="Crear o gestionar empresas" />
                                <Button Content="Eliminar" Padding="7,3"
                                        Command="{Binding EliminarEmpresaCommand}"
                                        FontSize="11" ToolTip="Eliminar empresa seleccionada" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Sección de Backup (Abajo) ── -->
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource DataGridHeaderBackgroundBrush}" 
                            Padding="12" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <TextBlock Text="Backups" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
                            
                            <Button Content="Realizar Backup" 
                                    Command="{Binding RealizarBackupCommand}"
                                    Style="{StaticResource AccentButton}"
                                    Margin="0,0,0,8" Padding="10,6" />
                            
                            <Button Content="Cargar Backup" 
                                    Command="{Binding RestaurarBackupCommand}"
                                    Padding="10,6" />
                        </StackPanel>
                    </Border>

                    <!-- ── Lista de empresas (ocupa el espacio restante) ── -->
                    <ListBox x:Name="ListEmpresas" BorderThickness="0" Padding="8" Background="Transparent"
                             ItemsSource="{Binding Empresas}"
                             SelectedItem="{Binding EmpresaSeleccionada, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding NombreEmpresa}" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Rif, StringFormat='RIF: {0}'}" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" 
                          Background="{StaticResource ControlBorderBrush}" />

            <TabControl x:Name="MainTabControl" Grid.Column="2" Margin="0">
                <TabItem Header="Dashboard">
                    <Frame x:Name="FrameDashboard" NavigationUIVisibility="Hidden" />
                </TabItem>
                <TabItem Header="Comprobantes">
                    <Frame x:Name="FrameComprobantes" NavigationUIVisibility="Hidden" />
                </TabItem>
                <TabItem Header="Movimientos">
                    <Frame x:Name="FrameMovimientos" NavigationUIVisibility="Hidden" />
                </TabItem>
                <TabItem Header="Plan de Cuentas">
                    <Frame x:Name="FramePlanCuentas" NavigationUIVisibility="Hidden" />
                </TabItem>
                <TabItem Header="Libros">
                    <TabControl x:Name="LibrosTabControl">
                        <TabItem Header="Libro Diario">
                            <Frame x:Name="FrameLibroDiario" NavigationUIVisibility="Hidden" />
                        </TabItem>
                        <TabItem Header="Libro Mayor">
                            <Frame x:Name="FrameLibroMayor" NavigationUIVisibility="Hidden" />
                        </TabItem>
                    </TabControl>
                </TabItem>
                <TabItem Header="Estado Financiero">
                    <Frame x:Name="FrameEstadoFinanciero" NavigationUIVisibility="Hidden" />
                </TabItem>
                <TabItem Header="Informes">
                    <Frame x:Name="FrameInformes" NavigationUIVisibility="Hidden" />
                </TabItem>
                <TabItem Header="Cobranza">
                    <Frame x:Name="FrameCobranza" NavigationUIVisibility="Hidden" />
                </TabItem>
                <TabItem Header="Documentos">
                    <Frame x:Name="FrameDocumentos" NavigationUIVisibility="Hidden" />
                </TabItem>
                <TabItem Header="Reexpresión">
                    <Frame x:Name="FrameReexpresion" NavigationUIVisibility="Hidden" />
                </TabItem>
                <TabItem Header="Bancos">
                    <Frame x:Name="FrameBancos" NavigationUIVisibility="Hidden" />
                </TabItem>
                <TabItem Header="Guía de Usuario">
                    <Frame x:Name="FrameAyuda" NavigationUIVisibility="Hidden" />
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
