<Page x:Class="Sistema_contable.Views.Informes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="Informes">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Informes" Style="{StaticResource TitleTextBlock}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Generar Reporte" Command="{Binding GenerarReporteCommand}" Style="{StaticResource AccentButton}" Margin="0,0,6,0" />
            <Button Content="Exportar PDF" Command="{Binding ExportarPdfCommand}" Margin="0,0,6,0" />
            <Button Content="Exportar Excel" Command="{Binding ExportarExcelCommand}" Margin="0,0,6,0" />
            <Separator Width="1" Margin="8,0" />
            <Button Content="Imprimir" Command="{Binding ImprimirCommand}" />
        </StackPanel>

        <GroupBox Grid.Row="2" Header="Parámetros del Reporte" Margin="0,0,0,12">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Tipo de Reporte:" VerticalAlignment="Center" />
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding TiposReporte}"
                          SelectedItem="{Binding TipoReporteSeleccionado, Mode=TwoWay}" />

                <Label Grid.Row="0" Grid.Column="3" Content="Fecha de Corte:" VerticalAlignment="Center" />
                <DatePicker Grid.Row="0" Grid.Column="4" SelectedDate="{Binding FechaCorte, Mode=TwoWay}" />

                <Label Grid.Row="0" Grid.Column="6" Content="Ejercicio:" VerticalAlignment="Center" />
                <ComboBox Grid.Row="0" Grid.Column="7" ItemsSource="{Binding EjerciciosDisponibles}"
                          SelectedItem="{Binding EjercicioSeleccionado, Mode=TwoWay}" />
            </Grid>
        </GroupBox>

        <TabControl Grid.Row="3">
            <TabItem Header="Vista Previa">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="{StaticResource WindowBackgroundBrush}" Padding="16" Margin="8">
                        <StackPanel>
                            <TextBlock Text="{Binding TituloReporte}" FontSize="18" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SubtituloReporte}" FontSize="14" 
                                       HorizontalAlignment="Center" Margin="0,0,0,16" 
                                       Foreground="{StaticResource TextSecondaryBrush}" />

                            <ItemsControl ItemsSource="{Binding Lineas}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="{Binding Margen}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Codigo}" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Nombre}" />
                                            <TextBlock Grid.Column="2" Text="{Binding Monto, StringFormat='Bs. {0:N2}'}" TextAlignment="Right" />
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding EsEncabezado}" Value="True">
                                                <Setter Property="TextElement.FontWeight" Value="Bold" />
                                                <Setter Property="TextElement.FontSize" Value="14" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EsCuentaPadre}" Value="True">
                                                <Setter Property="TextElement.FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EsTotal}" Value="True">
                                                <Setter Property="TextElement.FontWeight" Value="SemiBold" />
                                                <Setter Property="TextElement.FontSize" Value="13" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Margin="0,24,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NotasExplicativas}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding NotasExplicativas}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="NOTAS EXPLICATIVAS" FontWeight="Bold" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding NotasExplicativas}" TextWrapping="Wrap" FontStyle="Italic" />
                            </StackPanel>

                            <StackPanel Margin="0,16,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ConclusionesRecomendaciones}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ConclusionesRecomendaciones}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="CONCLUSIONES Y RECOMENDACIONES" FontWeight="Bold" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding ConclusionesRecomendaciones}" TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBlock Text="No hay datos para el reporte y filtros seleccionados." 
                                       Margin="0,16,0,0" FontStyle="Italic" 
                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding SinDatosVisibility}" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Notas y Análisis">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Notas Explicativas:" FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBox Grid.Row="1" Text="{Binding NotasExplicativas, UpdateSourceTrigger=PropertyChanged}" 
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Margin="0,0,0,16" />

                    <TextBlock Grid.Row="2" Text="Conclusiones y Recomendaciones:" FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBox Grid.Row="3" Text="{Binding ConclusionesRecomendaciones, UpdateSourceTrigger=PropertyChanged}" 
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" />
                </Grid>
            </TabItem>

            <TabItem Header="Gráficos">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource WindowBackgroundBrush}" 
                            BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1" 
                            Padding="16">
                        <TextBlock Text="Próximamente: gráficos de evolución patrimonial y comparativos entre periodos." 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic" TextWrapping="Wrap" TextAlignment="Center" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
