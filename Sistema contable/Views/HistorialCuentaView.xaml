<Window x:Class="Sistema_contable.Views.HistorialCuentaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historial de Reexpresiones" Height="350" Width="700"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F4F6F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Titulo}" FontSize="16" FontWeight="Bold" Foreground="#333" Margin="0,0,0,12" />

        <DataGrid Grid.Row="1" ItemsSource="{Binding Historiales}" AutoGenerateColumns="False" 
                  IsReadOnly="True" CanUserAddRows="False" Background="White" RowHeight="30"
                  SelectedItem="{Binding HistorialSeleccionado}"
                  SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaCalculo, StringFormat=dd/MM/yyyy}" Width="80" />
                <DataGridTextColumn Header="Factor" Binding="{Binding FactorAplicado, StringFormat=N6}" Width="80" />
                <DataGridTextColumn Header="Valor Original" Binding="{Binding ValorOriginal, StringFormat=N2}" Width="120" />
                <DataGridTextColumn Header="Ajuste" Binding="{Binding MontoAjuste, StringFormat=N2}" Width="100" />
                <DataGridTextColumn Header="Total Reexpresado" Binding="{Binding ValorAjustado, StringFormat=N2}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Deshacer Seleccionado" Command="{Binding DeshacerCommand}" 
                    Background="#E03A3E" Foreground="White" Padding="12,6" Margin="0,0,8,0" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand" />
            <Button Content="Cerrar" Command="{Binding CerrarCommand}" 
                    Background="#D9D9D9" Foreground="#333" Padding="12,6" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand" />
        </StackPanel>
    </Grid>
</Window>
