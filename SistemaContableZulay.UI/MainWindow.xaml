<Window x:Class="SistemaContableZulay.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema Contable Zulay Angola - Asiento Contable"
        Height="520" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Registro de Asiento Contable" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Margin="24,0,0,0" VerticalAlignment="Center"
                       Text="{Binding EstadoComprobante, StringFormat=Estado: {0}}"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Lineas}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código Cuenta" Binding="{Binding CodigoCuenta, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding DescripcionCuenta, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Debe" Binding="{Binding Debe, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                <DataGridTextColumn Header="Haber" Binding="{Binding Haber, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Agregar línea" Width="120" Margin="0,0,8,0"
                    Command="{Binding AgregarLineaCommand}"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="Total Debe:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding TotalDebe, StringFormat=N2}" VerticalAlignment="Center" MinWidth="80" Margin="0,0,16,0"/>
                <TextBlock Text="Total Haber:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding TotalHaber, StringFormat=N2}" VerticalAlignment="Center" MinWidth="80"/>
            </StackPanel>
        </Grid>

        <Button Grid.Row="3" Content="Guardar asiento" HorizontalAlignment="Right" Width="140" Padding="8,4"
                Command="{Binding ComandoGuardar}"/>
    </Grid>
</Window>
